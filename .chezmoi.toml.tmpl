{{- $machine_id := promptString "machine_id" -}}
{{- $personal_gpg_id := promptString "personal_gpg_id" -}}
{{- $work_email := promptString "work_email" -}}
{{- $work_gpg_id := promptString "work_gpg_id" -}}
{{- $work_org_alpha := promptString "work_org_alpha" -}}
{{- $work_org_beta := promptString "work_org_beta" -}}

[merge]
  command = "nvim"
  args = "-d"
[git]
  autoCommit = true
  autoPush = true
[data]
  machine_id = {{ $machine_id | quote }}
  personal_gpg_id = {{ $personal_gpg_id | quote }}
  work_email = {{ $work_email | quote }}
  work_gpg_id = {{ $work_gpg_id | quote }}
  work_org_alpha = {{ $work_org_alpha | quote }}
  work_org_beta = {{ $work_org_beta | quote }}

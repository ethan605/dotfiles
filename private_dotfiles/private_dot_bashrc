# vim:filetype=bash
export BAT_THEME=base16
export EDITOR=vim
export LESS='--ignore-case --jump-target=4 --LONG-PROMPT --no-init --quit-if-one-screen --RAW-CONTROL-CHARS'
export MANPAGER='nvim +Man!'
export TERM=xterm-256color

LS_COLORS="$(vivid generate molokai)"
export LS_COLORS

export FZF_DEFAULT_OPTS='
  --ansi
  --bind=ctrl-y:preview-up,ctrl-e:preview-down,ctrl-u:preview-page-up,ctrl-d:preview-page-down
  --color=fg+:7,bg+:0,hl:5,hl+:5
  --color=gutter:0,header:4,marker:2,pointer:5,prompt:2,spinner:3
  --cycle
  --marker="›"
  --pointer="›"
  --prompt="❯ "
  --reverse
  --no-height
'
BAT_PREVIEW_COMMAND='batcat --color=always --number --plain'
export FZF_CTRL_R_OPTS="
  --preview='echo {2..} | $BAT_PREVIEW_COMMAND --language=bash'
"
export FZF_CTRL_T_COMMAND='command fdfind -H --no-ignore-vcs -E .git -td -tf'
export FZF_CTRL_T_OPTS="
  --bind ctrl-/:toggle-preview
  --preview '
    if [[ -d {} ]]; then
      eza --group-directories-first --color=always -1F {};
    else
      $BAT_PREVIEW_COMMAND {};
    fi
  '
"

# Plugins
if [ -f "$HOME/.local/share/blesh/ble.sh" ]; then
  # shellcheck disable=SC1091
  source -- "$HOME/.local/share/blesh/ble.sh"
fi

if [ -f "$HOME/.fzf.bash" ]; then
  # shellcheck disable=SC1091
  source "$HOME/.fzf.bash"
fi

if [ -f "$HOME/.local/share/fzf-tab-completion/bash/fzf-bash-completion.sh" ]; then
  # shellcheck disable=SC1091
  source "$HOME/.local/share/fzf-tab-completion/bash/fzf-bash-completion.sh"
  bind -x '"\t": fzf_bash_completion'
fi

if command -v zoxide >/dev/null; then
  eval "$(zoxide init bash)"
fi

# Aliases
alias nano=nvim
alias v=nvim
alias vi=nvim
alias vim=nvim

alias bat=batcat
alias fd=fdfind
alias where=which

# Eza
alias ls='eza --group-directories-first --color=always --git --all'
alias l='ls --long --icons=always --header'
alias l1='ls --oneline'
alias lk='l --total-size --sort=size --reverse'
alias lr='l --tree --level=2'

# Git
alias gfl='git fetch --prune origin && git pull origin $(git branch --show-current)'

# Shortcuts
alias c=chezmoi
alias k=kubecolor

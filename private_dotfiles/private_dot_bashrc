# vim:filetype=bash
export BAT_THEME=base16
export EDITOR=vim
export LESS='--ignore-case --jump-target=4 --LONG-PROMPT --no-init --quit-if-one-screen --RAW-CONTROL-CHARS'
export MANPAGER='nvim +Man!'
export TERM=xterm-256color

LS_COLORS="$(vivid generate molokai)"
export LS_COLORS

export FZF_DEFAULT_OPTS='
  --ansi
  --bind=ctrl-y:preview-up,ctrl-e:preview-down,ctrl-u:preview-page-up,ctrl-d:preview-page-down
  --color=fg+:7,bg+:0,hl:5,hl+:5
  --color=gutter:0,header:4,marker:2,pointer:5,prompt:2,spinner:3
  --cycle
  --marker="›"
  --pointer="›"
  --prompt="❯ "
  --reverse
  --no-height
'
export FZF_CTRL_R_OPTS='
  --preview="echo {2..} | batcat --color=always --language=zsh --number --plain"
  --bind="ctrl-y:execute-silent(echo -n {2..} | pbcopy)+abort"
  --header="Press CTRL-Y to copy command into clipboard"
'

# Plugins
if [ -f "$HOME/ble.sh/out/ble.sh" ]; then
  # shellcheck disable=SC1091
  source "$HOME/ble.sh/out/ble.sh"

  set -o vi

  # ble-import -d integration/fzf-completion
  ble-import -d integration/fzf-key-bindings
fi

if command -v zoxide &>/dev/null; then
  eval "$(zoxide init bash)"
fi

# Aliases
alias bat=batcat
alias nano=nvim
alias v=nvim
alias vi=nvim
alias vim=nvim
alias where=which

# Eza
alias ls='eza --group-directories-first --color=always --git --all'
alias l='ls --long --icons=always --header'
alias l1='ls --oneline'
alias lk='l --total-size --sort=size --reverse'
alias lr='l --tree --level=2'

# Git
alias gfl='git fetch --prune origin && git pull origin $(git branch --show-current)'

# Shortcuts
alias c=chezmoi
alias k=kubecolor

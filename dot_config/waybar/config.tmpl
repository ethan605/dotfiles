// vim:fileencoding=utf-8:syntax=json5
{
  "position": "top",
  "layer": "bottom",
  "height": 30,

  "modules-left": [
    "sway/workspaces",
    "sway/mode",
    "custom/mpd"
  ],
  "modules-center": [
    "sway/window"
  ],
  "modules-right": [
    "network",
    "custom/vpn",
    "cpu",
    "memory",
    "temperature",
    "battery",
    "pulseaudio",
    "custom/ibus",
    "tray",
    "clock",
    "custom/arch"
  ],

  // -------------------------------------------------------------------------
  // Modules
  // -------------------------------------------------------------------------

  "sway/workspaces": {
    "all-outputs": false,
    "disable-scroll": true,
    "format": "{name}"
  },

  "sway/mode": {
    "format": "пӮ…    {}",
    "tooltip": false
  },

  "custom/mpd": {
    "return-type": "json",
    "interval": 3,
    "format": "{icon}  {}",
    "format-icons": {
      "paused": "пҒӢ ",
      "playing": "пҖҒ "
    },
    "exec": "$HOME/.local/bin/mpd-utils waybar-output", 
    "exec-if": "pgrep mpd",
    "on-click": "mpc toggle",
    "on-click-right": "termite --title=ncmpcpp --exec=ncmpcpp"
  },

  "sway/window": {
    "max-length": 50
  },

  "network": {
    "interval": 5,
    "format-wifi": "пҮ«    {essid}",
    "format-ethernet": "пғЁ    {ipaddr}",
    "format-disconnected": "пҗЎ ",
    "tooltip-format-wifi": "оҚ“{bandwidthUpBits} оҚҖ{bandwidthDownBits} | {ifname}: {ipaddr}",
    "tooltip-format-ethernet": "оҚ“{bandwidthUpBits} оҚҖ{bandwidthDownBits} | {ifname}: {ipaddr}",
    "tooltip-format-disconnected": "Network disconnected"
  },

  "custom/vpn": {
    "interval": 5,
    "format": "пҖЈ VPN",
    "exec": "echo '{\"class\": \"connected\"}'",
    "exec-if": "test -d /proc/sys/net/ipv4/conf/tun0",
    "return-type": "json"
  },

  "cpu": {
    "interval": 5,
    "format": "пӢӣ   {usage}%",
    "states": {
      "warning": 70,
      "critical": 90
    }
  },

  "memory": {
    "interval": 5,
    "format": "п”ё   {used:0.1f}GB",
    "tooltip-format": "Avail.: {avail:0.1f}GB | Total: {total:0.1f}GB",
    "states": {
      "warning": 70,
      "critical": 90
    }
  },

  "temperature": {
  {{- if eq .chezmoi.hostname "lunarch" }}
    "hwmon-path": "/sys/class/hwmon/hwmon1/temp1_input",
  {{- end }}
    "critical-threshold": 80,
    "interval": 5,
    "format": "{icon}  {temperatureC}В°C",
    "format-icons": [
      "пӢӢ",
      "пӢҠ",
      "пӢү",
      "пӢҲ",
      "пӢҲ" 
    ],
    "on-click": "termite --title=Sensors --exec='/usr/bin/zsh -c \"sensors | less -zn\"'",
    "tooltip": true
  },

  "pulseaudio": {
    "scroll-step": 1,
    "format": "{icon}  {volume}%",
    "format-bluetooth": "{icon}  {volume}% пҠ”",
    "format-muted": "п‘Ұ  ",
    "format-icons": {
      "car": "пҶ№ ",
      "handsfree": "пЈІ ",
      "headphones": "пҹҚ ",
      "headset": "пҹҚ ",
      "phone": "пЈІ ",
      "portable": "пҳң ",
      "default": ["пҖ§ ", "пҖЁ "]
    },
    "on-click": "pavucontrol"
  },

  "battery": {
    "interval": 10,
    "states": {
      "warning": 30,
      "critical": 15
    },
    // Connected to AC
    "format": "пғ§  {icon} {capacity}%",
    // Not connected to AC
    "format-discharging": "{icon} {capacity}%",
    "format-icons": [
      "пү„  ",
      "пүғ  ",
      "пүӮ  ",
      "пүҒ  ",
      "пүҖ  " 
    ],
    "tooltip": true
  },

  "custom/ibus": {
    "return-type": "json",
    "interval": 1,
    "format": " {icon} ",
    "format-icons": {
      "En": "рқ“” ",
      "Vi": "рқ“Ҙ "
    },
    "exec": "$HOME/.local/bin/ibus-engines waybar-output",
    "exec-on-event": "$HOME/.local/bin/ibus-engines waybar-output",
    "on-click": "$HOME/.local/bin/ibus-engines next-engine",
    "on-click-right": "swaymsg exec ibus-setup",
    "tooltip": true
  },

  "tray": {
    "icon-size": 22,
    "spacing": 10
  },

  "clock": {
    "interval": 1,
    "format": "{:%e %b %H:%M}",
    "tooltip-format": "{:%A %e %B %Y %H:%M:%S}"
  },

  "custom/arch": {
    "format": "пҢғ ",
    "tooltip": false
  }
}

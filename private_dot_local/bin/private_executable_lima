#!/usr/bin/env bash
set -o errexit
set -o pipefail
set -o nounset

function select_mail() {
  local select_mode=$1
  local account=$2

  local list=$(himalaya --account="$account" --output=json list)
  local list_size=$(echo "$list" | jq -r '.response | length')

  if [[ $list_size -eq 0 ]]; then
    echo "Empty mailbox"
    exit 0
  fi

  if [[ "$select_mode" = "multi" ]]; then
    local subjects=$(echo "$list" | jq -r '.response | sort_by(.date) | reverse[] | .subject' | fzf --multi)
    local subjects_arr
    readarray -t subjects_arr <<<"$subjects"

    local uids=()

    for subject in "${subjects_arr[@]}"; do
      local uid=$(echo "$list" | jq -r ".response[] | select(.subject==\"$subject\") | .uid")
      uids+=($uid)
    done

    echo $(IFS=, ; echo "${uids[*]}")
  else
    local subject=$(echo "$list" | jq -r '.response | sort_by(.date) | reverse[] | .subject' | fzf)
    local uid=$(echo "$list" | jq -r ".response[] | select(.subject==\"$subject\") | .uid")
    echo "$uid"
  fi
}

function browse_mails() {
  local account=${1:-primary}
  local uid=$(select_mail single "$account")

  local tmpfile=$(mktemp --suffix=.html)
  himalaya --account="$account" read --mime-type=html "$uid" > "$tmpfile"
  firefox "$tmpfile"
}

function delete_mails() {
  local account=${1:-primary}
  local uids=$(select_mail multi "$account")

  himalaya --account="$account" delete "$uids"
}

function move_mails() {
  local account=${1:-primary}
  local uids=$(select_mail multi "$account")
  local target=$(himalaya --account="$account" --output=json mailboxes | jq -r '.response[] | .name' | fzf)

  if [[ -z target ]]; then
    exit 0
  fi

  himalaya --account="$account" move "$uids" "$target"
}

function main() {
  local sub_command=$1
  shift

  case "$sub_command" in
    browse) browse_mails "$@";;
    delete) delete_mails "$@";;
    move) move_mails "$@";;
  esac
}

main "$@"

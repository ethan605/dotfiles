# [[[ Aliases
function fzfind() {
  preview="bat {-1} --color=always --style=numbers"
  find "$@" -type f | fzf --preview $preview
}

function chezdiff() {
  chezmoi diff "$@" 2> /dev/null | diff-so-fancy | less
}


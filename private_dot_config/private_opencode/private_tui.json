{
  "$schema": "https://opencode.ai/tui.json",
  "theme": "system",
  "keybinds": {
    "leader": "\\",
    "app_exit": "none",
    "messages_toggle_conceal": "none",
    "status_view": "none",
    "input_line_end": "ctrl+right",
    "input_line_home": "ctrl+left",
    "messages_first": "ctrl+g",
    "messages_last": "ctrl+alt+g",
    "messages_line_down": "ctrl+e",
    "messages_line_up": "ctrl+y",
    "messages_page_down": "ctrl+d",
    "messages_page_up": "ctrl+u",
    "session_background": "ctrl+alt+b",
    "session_child_cycle": "<leader>l,<leader>right",
    "session_child_cycle_reverse": "<leader>h,<leader>left",
    "session_child_first": "<leader>j,<leader>down",
    "session_list": "<leader>s",
    "session_parent": "<leader>k,<leader>up"
  },
  "scroll_speed": 3,
  "scroll_acceleration": {
    "enabled": true
  },
  "diff_style": "auto"
}

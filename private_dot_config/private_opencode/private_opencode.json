{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": ["anthropic", "google-vertex", "openai"],
  "autoupdate": true,
  "compaction": {
    "auto": true,
    "prune": true
  },
  "permission": {
    "*": "ask",

    "edit": "allow",
    "glob": "allow",
    "grep": "allow",
    "lsp": "allow",
    "question": "allow",
    "read": "allow",
    "skill": "allow",
    "task": "allow",
    "todoread": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",

    "bash": {
      "*": "ask",

      "git branch*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git remote*": "allow",
      "git show*": "allow",
      "git status*": "allow",
      "git worktree list*": "allow",

      "gh api *": "allow",
      "gh pr list*": "allow",
      "gh pr view*": "allow",
      "gh repo view*": "allow",

      "uv run mypy *": "allow",
      "uv run pytest *": "allow",
      "uv run ruff *": "allow",

      "pnpm *": "allow",
      "npm *": "allow",

      "notion_notion-*": "allow",
      "notion_notion-create-pages": "deny",
      "notion_notion-update-page": "deny",
      "notion_notion-move-pages": "deny",
      "notion_notion-duplicate-page": "deny",
      "notion_notion-create-database": "deny",
      "notion_notion-update-database": "deny",
      "notion_notion-create-comment": "deny"
    }
  },
  "agent": {
    "plan": {
      "color": "#57c7ff",
      "model": "anthropic/claude-opus-4-6",
      "variant": "max"
    },
    "build": {
      "color": "#ff6ac1",
      "model": "anthropic/claude-opus-4-6",
      "variant": "max"
    },
    "general": {
      "color": "#5af78e",
      "mode": "subagent",
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "system_prompt": "You are an Implementation Engineer. Read and strictly follow the instructions in ~/.config/opencode/GENERAL.md for your role and quality standards. DO NOT SPAWN SUBAGENTS - YOU NEED TO DO THE JOB YOURSELF!"
    },
    "explore": {
      "color": "#f3f99d",
      "mode": "subagent",
      "model": "anthropic/claude-sonnet-4-6",
      "variant": "high",
      "system_prompt": "You are an explorer who can efficiently roam through the codebase and documents. Prioritise the LSP tool and postgresql MCP over search grep/glob. DO NOT SPAWN SUBAGENTS - YOU NEED TO DO THE JOB YOURSELF!"
    },
    "reviewer": {
      "color": "#ff5c57",
      "mode": "subagent",
      "model": "google-vertex/gemini-3.1-pro-preview",
      "variant": "high",
      "system_prompt": "You are a Senior Software Engineer with a very high bar in terms of code review. Read and strictly follow the instructions in ~/.config/opencode/REVIEWER.md for your persona and review standards. DO NOT SPAWN SUBAGENTS - YOU NEED TO DO THE JOB YOURSELF!"
    }
  },
  "lsp": {
    "pyright": {
      "disabled": true
    },
    "basedpyright": {
      "command": ["basedpyright-langserver", "--stdio"],
      "extensions": [".py", ".pyi"]
    }
  },
  "mcp": {
    "postgresql": {
      "enabled": false,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@bytebase/dbhub",
        "--transport",
        "stdio",
        "--dsn",
        "{env:POSTGRES_CONNECTION_STRING}"
      ]
    },
    "neo4j": {
      "type": "local",
      "command": ["uvx", "mcp-neo4j-cypher", "--transport", "stdio"]
    },
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "oauth": {}
    },
    "miro": {
      "type": "remote",
      "url": "https://mcp.miro.com",
      "oauth": {}
    },
    "rivo": {
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "oauth": {}
    }
  }
}

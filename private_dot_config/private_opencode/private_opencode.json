{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": ["anthropic", "google-vertex", "openai", "fireworks-ai"],
  "autoupdate": false,
  "compaction": {
    "auto": true,
    "prune": true
  },
  "permission": {
    "*": "ask",

    "glob": "allow",
    "grep": "allow",
    "lsp": "allow",
    "question": "allow",
    "read": "allow",
    "skill": "allow",
    "task": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",

    "edit": {
      "*": "ask",
      "~/.config/**": "ask"
    },

    "auth0_auth0_get_*": "allow",
    "auth0_auth0_list_*": "allow",

    "google-docs_writeSpreadsheet": "deny",
    "google-docs_batchWrite": "deny",
    "google-docs_appendRows": "deny",
    "google-docs_createSpreadsheet": "deny",
    "google-docs_appendTableRows": "deny",
    "google-docs_download*": "allow",
    "google-docs_get*": "allow",
    "google-docs_list*": "allow",
    "google-docs_read*": "allow",
    "google-docs_search*": "allow",
    "google-docs_triageInbox": "allow",

    "linear_extract_*": "allow",
    "linear_get_*": "allow",
    "linear_list_*": "allow",
    "linear_search_*": "allow",

    "miro_board_*": "allow",
    "miro_context_*": "allow",
    "miro_diagram_get_dsl": "allow",
    "miro_doc_get": "allow",
    "miro_image_get_*": "allow",
    "miro_table_list_rows": "allow",

    "neo4j-cypher_get_*": "allow",
    "neo4j-cypher_read_*": "allow",

    "rivo_atlassianUserInfo": "allow",
    "rivo_fetch": "allow",
    "rivo_get*": "allow",
    "rivo_lookup*": "allow",
    "rivo_search*": "allow",

    "slack_slack_get_*": "allow",
    "slack_slack_list_*": "allow",
    "slack_slack_read_*": "allow",
    "slack_slack_search_*": "allow",

    "teamcity_teamcity_build_log": "allow",
    "teamcity_teamcity_rest_get": "allow",

    "bash": {
      "*": "ask",

      "cat *": "allow",
      "find *": "allow",
      "find *-delete*": "ask",
      "find *-exec*": "ask",
      "find *-fls*": "ask",
      "find *-fprint*": "ask",
      "find *-ok*": "ask",
      "grep *": "allow",
      "head *": "allow",
      "ls *": "allow",
      "read *": "allow",
      "tail *": "allow",

      "rtk cat*": "allow",
      "rtk find*": "allow",
      "rtk find*-delete*": "ask",
      "rtk find*-exec*": "ask",
      "rtk find*-fls*": "ask",
      "rtk find*-fprint*": "ask",
      "rtk find*-ok*": "ask",
      "rtk grep*": "allow",
      "rtk head*": "allow",
      "rtk ls*": "allow",
      "rtk read *": "allow",
      "rtk tail*": "allow",

      "xargs grep *": "allow",
      "xargs head *": "allow",
      "xargs ls *": "allow",
      "xargs tail *": "allow",

      "git branch": "allow",
      "git branch -a*": "allow",
      "git branch -r*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git remote": "allow",
      "git remote -v": "allow",
      "git show*": "allow",
      "git status*": "allow",
      "git worktree list*": "allow",
      "rtk git branch -a*": "allow",
      "rtk git branch -r*": "allow",
      "rtk git branch": "allow",
      "rtk git diff*": "allow",
      "rtk git log*": "allow",
      "rtk git remote -v": "allow",
      "rtk git remote": "allow",
      "rtk git show*": "allow",
      "rtk git status*": "allow",
      "rtk git worktree list*": "allow",

      "gh pr list *": "allow",
      "gh pr view *": "allow",
      "gh repo view *": "allow",
      "rtk gh pr list *": "allow",
      "rtk gh pr view *": "allow",
      "rtk gh repo view *": "allow",

      "gh pr create*": "ask",
      "rtk gh pr create*": "ask",

      "uv run mypy *": "allow",
      "uv run pytest *": "allow",
      "uv run ruff *": "allow",
      "rtk uv run mypy *": "allow",
      "rtk uv run pytest *": "allow",
      "rtk uv run ruff *": "allow",

      "pnpm test*": "allow",
      "pnpm list*": "allow",
      "pnpm ls*": "allow",
      "pnpm info *": "allow",
      "pnpm outdated*": "allow",
      "pnpm why *": "allow",
      "rtk pnpm test*": "allow",
      "rtk pnpm list*": "allow",
      "rtk pnpm ls*": "allow",
      "rtk pnpm info *": "allow",
      "rtk pnpm outdated*": "allow",
      "rtk pnpm why *": "allow",

      "npm test*": "allow",
      "npm list*": "allow",
      "npm ls*": "allow",
      "npm info *": "allow",
      "npm outdated*": "allow",
      "npm why *": "allow",
      "rtk npm test*": "allow",
      "rtk npm list*": "allow",
      "rtk npm ls*": "allow",
      "rtk npm info *": "allow",
      "rtk npm outdated*": "allow",
      "rtk npm why *": "allow",

      "chezmoi *": "ask",
      "rtk chezmoi *": "ask"
    }
  },
  "default_agent": "plan",
  "agent": {
    "plan": {
      "color": "#57c7ff",
      "model": "anthropic/claude-opus-4-8",
      "variant": "high"
    },
    "build": {
      "color": "#ff6ac1",
      "model": "anthropic/claude-opus-4-8",
      "variant": "high"
    },
    "general": {
      "color": "#5af78e",
      "mode": "subagent",
      "model": "openai/gpt-5.6-terra",
      "variant": "xhigh",
      "permission": {
        "task": "deny"
      },
      "prompt": "{file:./GENERAL.md}"
    },
    "explore": {
      "color": "#f3f99d",
      "mode": "subagent",
      "model": "fireworks-ai/accounts/fireworks/routers/glm-5p2-fast",
      "permission": {
        "edit": "deny",
        "task": "deny"
      },
      "prompt": "{file:./EXPLORE.md}"
    },
    "reviewer": {
      "color": "#ff5c57",
      "mode": "subagent",
      "model": "openai/gpt-5.6-sol",
      "variant": "xhigh",
      "permission": {
        "edit": "deny",
        "task": "deny"
      },
      "prompt": "{file:./REVIEWER.md}"
    },
    "compaction": {
      "model": "anthropic/claude-sonnet-5"
    }
  },
  "plugin": [
    "opencode-claude-bridge@1.10.12",
    "superpowers@git+https://github.com/ethan605/superpowers.git#304b00295fad9cb18c47d170ff2872840a14d421"
  ],
  "lsp": {
    "pyright": {
      "disabled": true
    },
    "basedpyright": {
      "command": ["basedpyright-langserver", "--stdio"],
      "extensions": [".py", ".pyi"]
    }
  },
  "mcp": {
    "auth0": {
      "enabled": false,
      "type": "local",
      "command": ["npx", "-y", "@auth0/auth0-mcp-server", "run"],
      "environment": {
        "DEBUG": "auth0-mcp"
      }
    },
    "google-docs": {
      "enabled": true,
      "type": "local",
      "command": ["npx", "-y", "@a-bonus/google-docs-mcp"],
      "environment": {
        "GOOGLE_CLIENT_ID": "{env:GOOGLE_DOCS_MCP_CLIENT_ID}",
        "GOOGLE_CLIENT_SECRET": "{env:GOOGLE_DOCS_MCP_CLIENT_SECRET}"
      }
    },
    "grafana": {
      "enabled": false,
      "type": "local",
      "command": ["uvx", "mcp-grafana"],
      "environment": {
        "GRAFANA_URL": "{env:GRAFANA_URL}",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "{env:GRAFANA_SERVICE_ACCOUNT_TOKEN}"
      }
    },
    "linear": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "oauth": {}
    },
    "miro": {
      "enabled": false,
      "type": "remote",
      "url": "https://mcp.miro.com",
      "oauth": {}
    },
    "neo4j-cypher": {
      "enabled": false,
      "type": "local",
      "command": ["uvx", "mcp-neo4j-cypher", "--transport", "stdio"],
      "environment": {
        "NEO4J_URI": "{env:NEO4J_URI}",
        "NEO4J_USERNAME": "{env:NEO4J_USERNAME}",
        "NEO4J_PASSWORD": "{env:NEO4J_PASSWORD}",
        "NEO4J_DATABASE": "{env:NEO4J_DATABASE}"
      }
    },
    "postgresql": {
      "enabled": false,
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@bytebase/dbhub",
        "--transport",
        "stdio",
        "--dsn",
        "{env:POSTGRES_CONNECTION_STRING}"
      ]
    },
    "rivo": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.atlassian.com/v1/mcp",
      "oauth": {}
    },
    "slack": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.slack.com/mcp",
      "oauth": {
        "clientId": "1601185624273.8899143856786",
        "redirectUri": "http://localhost:3118/callback"
      }
    },
    "teamcity": {
      "enabled": true,
      "type": "remote",
      "url": "https://live.neo4j-build.io/app/mcp",
      "headers": {
        "Authorization": "Bearer {env:TC_AUTH_TOKEN}"
      }
    }
  }
}

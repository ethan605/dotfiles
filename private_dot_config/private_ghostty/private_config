# vim:filetype=config
cursor-style = block
shell-integration = none
term = xterm-ghostty 

# Colorscheme
palette = 0=#282a36
palette = 1=#ff5c57
palette = 2=#5af78e
palette = 3=#f3f99d
palette = 4=#57c7ff
palette = 5=#ff6ac1
palette = 6=#9aedfe
palette = 7=#eff0eb
palette = 8=#78787e
palette = 9=#ff5c57
palette = 10=#5af78e
palette = 11=#f3f99d
palette = 12=#57c7ff
palette = 13=#ff6ac1
palette = 14=#9aedfe
palette = 15=#eff0eb

background = #282a36
foreground = #eff0eb
cursor-color = #eff0eb
selection-background = #e2e4e5
selection-foreground = #43454f

# Font fallback test:
# Α Β Γ Δ Ε Ζ Η Θ Ι Κ Λ Μ Ν Ξ Ο Π Ρ Σ _ Τ Υ Φ Χ Ψ Ω
# α β γ δ ε ζ η θ ι κ λ μ ν ξ ο π ρ σ ς τ υ φ χ ψ ω
font-size = 18
font-family = ""
font-family = OperatorMonoSSm Nerd Font
font-family = Source Code Pro
font-family = Roboto Mono
font-thicken = true
font-style = Light
font-style-bold = Regular
font-style-bold-italic = Italic
font-style-italic = Light Italic
# font-codepoint-map = U+0391-U+03C9=SamsungSans Nerd Font

font-family = MonoLisa
# widespace without coding ligatures: <$> </> -- {||} ##
font-feature = -liga,+calt,+dlig
# slash zero, hex: 0xdeadc0de, alt g, @, ()
font-feature = +zero,+ss11,+ss04,+ss06,+ss08
# script variant
font-feature = +ss02

# adjust-cell-height = -5%
# adjust-cell-width = -5%
adjust-underline-thickness = -50%

confirm-close-surface = false
fullscreen = false
link-previews = false
link-url = true
quit-after-last-window-closed = false
title = ""
window-decoration = none
window-inherit-working-directory = true
window-subtitle = false
working-directory = home

# Keybinds
keybind = ctrl+x>c=new_split:auto
keybind = ctrl+x>equal=equalize_splits
keybind = ctrl+x>x=close_surface

keybind = ctrl+x>h=goto_split:left
keybind = ctrl+x>j=goto_split:down
keybind = ctrl+x>k=goto_split:up
keybind = ctrl+x>l=goto_split:right

keybind = ctrl+x>shift+h=resize_split:left,250
keybind = ctrl+x>shift+l=resize_split:right,250

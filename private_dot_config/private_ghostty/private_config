# vim:filetype=config
cursor-style = block
shell-integration-features = no-cursor
term = xterm-ghostty 

# Colorscheme
palette = 0=#282a36
palette = 1=#ff5c57
palette = 2=#5af78e
palette = 3=#f3f99d
palette = 4=#57c7ff
palette = 5=#ff6ac1
palette = 6=#9aedfe
palette = 7=#eff0eb
palette = 8=#686868
palette = 9=#ff5c57
palette = 10=#5af78e
palette = 11=#f3f99d
palette = 12=#57c7ff
palette = 13=#ff6ac1
palette = 14=#9aedfe
palette = 15=#eff0eb

background = #282a36
foreground = #eff0eb

# Font fallback test:
# Α Β Γ Δ Ε Ζ Η Θ Ι Κ Λ Μ Ν Ξ Ο Π Ρ Σ . Τ Υ Φ Χ Ψ Ω
# α β γ δ ε ζ η θ ι κ λ μ ν ξ ο π ρ σ ς τ υ φ χ ψ ω
font-family = ""
font-family = OperatorMonoSSm Nerd Font
font-family = Source Code Pro
font-family = Roboto Mono
font-style-bold = Medium
font-style-bold-italic = Medium Italic
font-style-italic = Italic
font-size = 18
adjust-underline-thickness = -75%
# font-codepoint-map = U+0391-U+03C9=SamsungSans Nerd Font
# font-thicken = true
# adjust-cell-height = +10%
# adjust-cell-width = -5%

fullscreen = false
link-previews = false
link-url = true
title = ""
window-decoration = false
window-subtitle = false

# Keybinds
keybind = ctrl+x>c=new_split:auto
keybind = ctrl+x>equal=equalize_splits
keybind = ctrl+x>x=close_surface

keybind = ctrl+x>h=goto_split:left
keybind = ctrl+x>j=goto_split:down
keybind = ctrl+x>k=goto_split:up
keybind = ctrl+x>l=goto_split:right

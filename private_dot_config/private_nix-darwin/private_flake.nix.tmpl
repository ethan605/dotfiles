# vim:filetype=nix
{
  description = "My nix-darwin system configuration";

  inputs = {
    determinate.url = "https://flakehub.com/f/DeterminateSystems/determinate/3";
    nixpkgs.url = "github:NixOS/nixpkgs/nixpkgs-unstable";
    nixpkgs-25-11.url = "github:NixOS/nixpkgs/nixpkgs-25.11-darwin";
    # Based on the last successful build: https://hydra.nixos.org/job/nixpkgs/unstable/direnv.aarch64-darwin
    nixpkgs-direnv.url = "github:NixOS/nixpkgs/a4fb16db2751d9c9e5f3512c697d2ac49d406789";

    nix-darwin = {
      url = "github:nix-darwin/nix-darwin";
      inputs.nixpkgs.follows = "nixpkgs";
    };

    nix-homebrew.url = "github:zhaofengli/nix-homebrew";

    home-manager = {
      url = "github:nix-community/home-manager";
      inputs.nixpkgs.follows = "nixpkgs";
    };
  };

  outputs =
    {
      determinate,
      nix-darwin,
      nix-homebrew,
      home-manager,
      ...
    }@inputs:
    let
      system = "aarch64-darwin";
      username = "{{ .chezmoi.username }}";
      hostname = "macintosh-{{ .machine_id }}";
      home-dir = "/Users/${username}";
    in
    {
      darwinConfigurations.${hostname} = nix-darwin.lib.darwinSystem {
        specialArgs = { inherit hostname username home-dir; };
        system = system;
        modules = [
          determinate.darwinModules.default
          nix-homebrew.darwinModules.nix-homebrew
          home-manager.darwinModules.home-manager
          (import ./overlays.nix { inherit inputs system; })
          ./configuration.nix
        ];
      };
    };
}
